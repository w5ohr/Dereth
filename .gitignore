# OS cruft
.DS_Store

# Claude Code local (per-user) settings — keep launch.json shared, ignore local overrides
.claude/settings.local.json

# server runtime data (SQLite accounts/characters) — never commit player data
server/*.db
__pycache__/
*.pyc

# experimental single-avatar drop-in (assets/avatar.glb) stays user-supplied / ignored.
# The assets/models/ pack IS committed (self-hosted, served to clients); repopulate or
# extend it with `python3 assets/fetch-models.py`.
assets/*.glb
assets/*.gltf
