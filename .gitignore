# OS cruft
.DS_Store

# Claude Code local (per-user) settings — keep launch.json shared, ignore local overrides
.claude/settings.local.json

# server runtime data (SQLite accounts/characters) — never commit player data
server/*.db
__pycache__/
*.pyc

# external avatar / rigged models — multi-MB binaries, self-hosted so the game's own
# static server serves them to clients. Reproduce with `python3 assets/fetch-models.py`.
assets/*.glb
assets/*.gltf
assets/models/
